// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum Currency {
  USD
  KZT
  EUR
}

enum AccountType {
  CASH
  BANK
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  ADJUSTMENT
}

model User {
  id           String    @id @default(uuid())
  firstName    String?
  lastName     String?
  email        String    @unique
  passwordHash String
  refreshTokenHash String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt


  defaultCurrency Currency? @default(KZT)

  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  transfers    Transfer[]
}

model Account { 
  id             String      @id @default(uuid())
  userId         String
  sequence Int @unique @default(autoincrement())
  accountNumber String? @unique 
  name           String
  type           AccountType
  currency       Currency
  initialBalance Decimal     @default(0.0) @db.Decimal(18, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  transfersOut Transfer[]    @relation("TransferFromAccount")
  transfersIn  Transfer[]    @relation("TransferToAccount")

  @@index([userId])
  @@unique([userId, name])
}

model Category {
  id        String       @id @default(uuid())
  userId    String
  name      String
  type      CategoryType
  colorKey  String?
  iconKey   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@unique([userId, type, name])
}

model Transaction {
  id         String          @id @default(uuid())
  userId     String
  accountId  String
  categoryId String?
  type       TransactionType

  amount     Decimal         @db.Decimal(18, 2)
  originalAmount   Decimal?  @db.Decimal(18, 2)
  originalCurrency Currency?
  exchangeRate     Decimal?  @db.Decimal(18, 8)

  occurredAt DateTime
  note       String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([categoryId, occurredAt])
}

model Transfer {
  id            String   @id @default(uuid())
  userId        String
  fromAccountId String
  toAccountId   String

  fromAmount   Decimal @db.Decimal(18, 2)
  toAmount     Decimal @db.Decimal(18, 2)
  exchangeRate Decimal @db.Decimal(18, 8)
  occurredAt    DateTime
  note          String?
  createdAt     DateTime @default(now())
  isCanceled    Boolean  @default(false)

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount Account @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount   Account @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([fromAccountId, occurredAt])
  @@index([toAccountId, occurredAt])
}