// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum Currency {
  USD
  KZT
  EUR
}

enum AccountType {
  CASH
  BANK
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  ADJUSTMENT
}

model User {
  id           String    @id @default(uuid())
  firstName    String?
  lastName     String?
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  transfers    Transfer[]
}

// Account - это источник или назначение денег. Например, наличные, банковский счет, кредитная карта и т.д.
model Account { 
  id             String      @id @default(uuid())
  userId         String
  sequence Int @unique @default(autoincrement())
  accountNumber String? @unique 
  name           String
  type           AccountType
  currency       Currency
  initialBalance Decimal     @default(0.0) @db.Decimal(18, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  transfersOut Transfer[]    @relation("TransferFromAccount")
  transfersIn  Transfer[]    @relation("TransferToAccount")

  @@index([userId])
  @@unique([userId, name])
}

// Category - это классификация транзакций. Например, зарплата, продукты, развлечения и т.д. Категории могут быть двух типов: доходы и расходы. Транзакция может быть связана только с одной категорией, но категория может быть связана с несколькими транзакциями.
model Category {
  id        String       @id @default(uuid())
  userId    String
  name      String
  type      CategoryType
  color     String?
  icon      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@unique([userId, type, name])
}

// Transaction - это запись о финансовой операции. Она связана с одним аккаунтом и одной категорией. Транзакция может быть двух типов: доход или расход. Например, если пользователь получает зарплату, то это будет транзакция типа доход, связанная с категорией "зарплата" и аккаунтом "банковский счет". Если пользователь покупает продукты, то это будет транзакция типа расход, связанная с категорией "продукты" и аккаунтом "наличные".
model Transaction {
  id         String          @id @default(uuid())
  userId     String
  accountId  String
  categoryId String?
  type       TransactionType
  amount     Decimal         @db.Decimal(18, 2)
  occurredAt DateTime
  note       String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([categoryId, occurredAt])
}

model Transfer {
  id            String   @id @default(uuid())
  userId        String
  fromAccountId String
  toAccountId   String
  amount        Decimal  @db.Decimal(18, 2)
  occurredAt    DateTime
  note          String?
  createdAt     DateTime @default(now())

  isCanceled    Boolean  @default(false)

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount Account @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount   Account @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([fromAccountId, occurredAt])
  @@index([toAccountId, occurredAt])
}
